# ── Alexandria-AI — variáveis de ambiente ──────────────────────────
#
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# O projeto funciona 100% off-grid com as configurações padrão.
# ────────────────────────────────────────────────────────────────────

# Modelo de embeddings (sentence-transformers).
# Opções recomendadas (multilínguae, leve):
#   paraphrase-multilingual-MiniLM-L12-v2  ← padrão (PT + EN, ~120MB)
#   all-MiniLM-L6-v2                       ← apenas EN, mais rápido
#   intfloat/multilingual-e5-small         ← melhor qualidade, maior
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Tamanho de cada chunk de texto (em caracteres)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Diretório onde os arquivos carregados e o índice serão salvos
DATA_DIR=data

# Upload público (hardening básico)
# true  -> aceita uploads no endpoint /ingest
# false -> bloqueia upload público (retorna 403)
PUBLIC_UPLOAD_ENABLED=true

# Material inicial padrão (Fábulas de Esopo)
# true  -> garante que o arquivo padrão seja indexado no startup
# false -> não adiciona material inicial automaticamente
SEED_AESOP_ON_STARTUP=true

# Tamanho máximo por arquivo em bytes (padrão: 10MB)
MAX_UPLOAD_BYTES=10485760

# OCR catalyst-like (PDF escaneado e imagens)
# Requer binários do sistema: tesseract-ocr e poppler-utils
OCR_ENGINE_ENABLED=true
OCR_LANGUAGES=por+eng
OCR_FORCE_PDF=false
OCR_MAX_PDF_PAGES=12
OCR_MIN_PDF_CHARS=120

# Porta da API
PORT=8000

# Pausa entre requests ao Gutenberg (segundos) — respeite o servidor!
GUTENBERG_REQUEST_DELAY=1.5

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
